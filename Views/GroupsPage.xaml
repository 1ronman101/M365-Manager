<Page
    x:Class="M365Manager.Views.GroupsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:M365Manager.Models"
    xmlns:local="using:M365Manager.Views"
    Loaded="Page_Loaded">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
        <local:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis" />
    </Page.Resources>

    <ScrollViewer Padding="40,32">
        <StackPanel MaxWidth="{StaticResource ContentMaxWidth}">

            <TextBlock Text="Teams &amp; Groups"
                       Style="{StaticResource PageHeaderStyle}" />
            <TextBlock Text="View and manage the members of your Microsoft 365 teams and groups."
                       Opacity="0.7"
                       Margin="0,0,0,24" />

            <!-- Loading -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="40" Height="40"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Margin="0,20" />

            <!-- Groups List (shown when no group is selected) -->
            <StackPanel Visibility="{x:Bind ViewModel.IsGroupSelected, Mode=OneWay, Converter={StaticResource InvertedBoolToVis}}">

                <ListView ItemsSource="{x:Bind ViewModel.Groups}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:GroupItem">
                            <Grid Padding="8,12" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <FontIcon Glyph="{x:Bind Icon}"
                                          FontSize="24"
                                          Grid.Column="0"
                                          VerticalAlignment="Center"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Description}"
                                               Opacity="0.6" FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="400" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind TypeLabel}"
                                               FontSize="11"
                                               Opacity="0.5"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Text="{x:Bind MemberCountText}"
                                               FontSize="12"
                                               Opacity="0.7"
                                               HorizontalAlignment="Right" />
                                </StackPanel>

                                <Button Content="View Members"
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        Tag="{x:Bind}"
                                        Click="ViewGroupMembers_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- Group Detail (shown when a group is selected) -->
            <StackPanel Visibility="{x:Bind ViewModel.IsGroupSelected, Mode=OneWay, Converter={StaticResource BoolToVis}}">

                <Button Content="&#xE72B;  Back to all groups"
                        Click="BackToGroups_Click"
                        Margin="0,0,0,12" />

                <!-- Group Header -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{x:Bind ViewModel.SelectedGroup.DisplayName, Mode=OneWay}"
                                       FontSize="22" FontWeight="SemiBold" />
                            <Border CornerRadius="4" Padding="8,2"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.SelectedGroup.TypeLabel, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.SelectedGroup.Description, Mode=OneWay}"
                                   Opacity="0.6" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Add Member -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Add a Member"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="0" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{x:Bind ViewModel.AddMemberSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Search for a person to add..."
                                     MinWidth="350"
                                     KeyDown="AddMemberSearch_KeyDown" />
                            <Button Content="Search"
                                    Click="SearchMemberToAdd_Click"
                                    Padding="12,6" />
                            <ProgressRing IsActive="{x:Bind ViewModel.IsSearchingMembers, Mode=OneWay}"
                                          Width="20" Height="20"
                                          Visibility="{x:Bind ViewModel.IsSearchingMembers, Mode=OneWay}" />
                        </StackPanel>

                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.MemberSearchResults}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:AppUser">
                                    <Grid Padding="4,6" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Email}" FontSize="11" Opacity="0.6" />
                                        </StackPanel>
                                        <Button Content="Add"
                                                Grid.Column="1"
                                                Tag="{x:Bind}"
                                                Click="AddMember_Click"
                                                Padding="12,4" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- Members List -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Margin="0">
                            <Run Text="Members" />
                            <Run Text=" (" /><Run Text="{x:Bind ViewModel.Members.Count, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>

                        <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingMembers, Mode=OneWay}"
                                      Width="30" Height="30"
                                      Visibility="{x:Bind ViewModel.IsLoadingMembers, Mode=OneWay}" />

                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Members}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:GroupMember">
                                    <Grid Padding="4,8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <PersonPicture DisplayName="{x:Bind DisplayName}"
                                                       Width="32" Height="32"
                                                       Grid.Column="0" />

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Email}"
                                                       FontSize="11" Opacity="0.6" />
                                        </StackPanel>

                                        <Button Content="Remove"
                                                Grid.Column="2"
                                                FontSize="12"
                                                Padding="8,4"
                                                Tag="{x:Bind}"
                                                Click="RemoveMember_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Height="40" />
        </StackPanel>
    </ScrollViewer>
</Page>

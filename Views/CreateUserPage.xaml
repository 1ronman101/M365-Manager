<Page
    x:Class="M365Manager.Views.CreateUserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:M365Manager.Views"
    xmlns:models="using:M365Manager.Models"
    Loaded="Page_Loaded">

    <ScrollViewer Padding="40,32">
        <StackPanel MaxWidth="{StaticResource ContentMaxWidth}">

            <TextBlock Text="Create New Employee"
                       Style="{StaticResource PageHeaderStyle}" />
            <TextBlock Text="Fill in the details below to set up a new Microsoft 365 account."
                       Opacity="0.7"
                       Margin="0,0,0,24" />

            <!-- Loading -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="40" Height="40"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Margin="0,20" />

            <!-- Error -->
            <InfoBar Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     Severity="Error"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     IsClosable="True"
                     Margin="0,0,0,16" />

            <!-- Form (hidden when showing summary) -->
            <StackPanel x:Name="FormPanel"
                        Visibility="{x:Bind ViewModel.ShowSummary, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibility}}">

                <!-- Personal Info Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Personal Information"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <StackPanel>
                                <TextBox Header="First Name *"
                                         Text="{x:Bind ViewModel.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="e.g. John"
                                         MinWidth="220" />
                                <TextBlock Text="{x:Bind ViewModel.FirstNameError, Mode=OneWay}"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                           FontSize="12"
                                           Margin="0,2,0,8" />
                            </StackPanel>
                            <StackPanel>
                                <TextBox Header="Last Name *"
                                         Text="{x:Bind ViewModel.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="e.g. Smith"
                                         MinWidth="220" />
                                <TextBlock Text="{x:Bind ViewModel.LastNameError, Mode=OneWay}"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                           FontSize="12"
                                           Margin="0,2,0,8" />
                            </StackPanel>
                        </StackPanel>

                        <TextBox Header="Display Name (auto-generated, editable)"
                                 Text="{x:Bind ViewModel.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="460"
                                 Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBox Header="Job Title"
                                     Text="{x:Bind ViewModel.JobTitle, Mode=TwoWay}"
                                     PlaceholderText="e.g. Sales Manager"
                                     MinWidth="220" />
                            <TextBox Header="Department"
                                     Text="{x:Bind ViewModel.Department, Mode=TwoWay}"
                                     PlaceholderText="e.g. Sales"
                                     MinWidth="220" />
                        </StackPanel>

                        <TextBox Header="Office Location"
                                 Text="{x:Bind ViewModel.OfficeLocation, Mode=TwoWay}"
                                 PlaceholderText="e.g. Building A, Floor 2"
                                 MinWidth="460"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Account Settings Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Account Settings"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12" />

                        <StackPanel>
                            <TextBox Header="Email Address * (auto-generated, editable)"
                                     Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="john.smith@yourdomain.com"
                                     MinWidth="460" />
                            <TextBlock Text="{x:Bind ViewModel.EmailError, Mode=OneWay}"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       FontSize="12"
                                       Margin="0,2,0,8" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                            <TextBox Header="Temporary Password *"
                                     Text="{x:Bind ViewModel.Password, Mode=TwoWay}"
                                     MinWidth="300" />
                            <Button Content="Generate New Password"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,1"
                                    Click="GeneratePassword_Click" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.PasswordError, Mode=OneWay}"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,4" />

                        <CheckBox Content="User must change password on first sign-in"
                                  IsChecked="{x:Bind ViewModel.ForceChangePassword, Mode=TwoWay}"
                                  Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- License Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Microsoft 365 License"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,12" />

                        <ComboBox Header="Assign a license"
                                  ItemsSource="{x:Bind ViewModel.AvailableLicenses}"
                                  SelectedItem="{x:Bind ViewModel.SelectedLicense, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayText"
                                  MinWidth="400" />
                    </StackPanel>
                </Border>

                <!-- Admin Role Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Admin Role (optional)"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="Most employees should be left as 'Standard User'. Only assign admin roles if specifically needed."
                                   Opacity="0.6"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <ComboBox Header="Role"
                                  ItemsSource="{x:Bind ViewModel.AvailableRoles}"
                                  SelectedItem="{x:Bind ViewModel.SelectedRole, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  MinWidth="400" />
                    </StackPanel>
                </Border>

                <!-- Groups Card -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Teams &amp; Groups"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,4" />
                        <TextBlock Text="Tick the teams or groups this person should be added to."
                                   Opacity="0.6"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.AvailableGroups}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:GroupItem">
                                    <CheckBox Content="{x:Bind DisplayName}"
                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                              Margin="0,2" />
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <TextBlock Text="No groups found in your tenant."
                                   Opacity="0.5"
                                   Visibility="{x:Bind ViewModel.AvailableGroups.Count, Mode=OneWay, Converter={StaticResource ZeroToVisibility}}" />
                    </StackPanel>
                </Border>

                <!-- Create Button -->
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,32">
                    <Button Content="Create Employee Account"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="24,12"
                            Click="CreateUser_Click"
                            IsEnabled="{x:Bind ViewModel.IsCreating, Mode=OneWay, Converter={StaticResource InvertedBool}}" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsCreating, Mode=OneWay}"
                                  Width="24" Height="24"
                                  Visibility="{x:Bind ViewModel.IsCreating, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!-- Summary (shown after creation) -->
            <StackPanel x:Name="SummaryPanel"
                        Visibility="{x:Bind ViewModel.ShowSummary, Mode=OneWay}">

                <InfoBar Title="Employee Created Successfully!"
                         Message="{x:Bind ViewModel.CreatedUser.DisplayName, Mode=OneWay}"
                         Severity="Success"
                         IsOpen="True"
                         IsClosable="False"
                         Margin="0,0,0,16" />

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Account Summary"
                                   Style="{StaticResource SectionHeaderStyle}" Margin="0" />

                        <TextBlock Text="{x:Bind ViewModel.SummaryText, Mode=OneWay}"
                                   FontFamily="Consolas"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True" />

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                            <Button Content="&#xE8C8;  Copy Welcome Info to Clipboard"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="16,10"
                                    Click="CopyWelcomeInfo_Click" />
                            <Button Content="Create Another Employee"
                                    Padding="16,10"
                                    Click="ResetForm_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>

    <Page.Resources>
        <local:InvertedBoolConverter x:Key="InvertedBool" />
        <local:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibility" />
        <local:ZeroCountToVisibilityConverter x:Key="ZeroToVisibility" />
    </Page.Resources>
</Page>

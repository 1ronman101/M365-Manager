<Page
    x:Class="M365Manager.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <ScrollViewer Padding="40,32">
        <StackPanel MaxWidth="{StaticResource ContentMaxWidth}">

            <!-- Welcome -->
            <TextBlock Text="{x:Bind ViewModel.WelcomeMessage, Mode=OneWay}"
                       Style="{StaticResource PageHeaderStyle}" />

            <TextBlock Text="Here's an overview of your Microsoft 365 environment."
                       Opacity="0.7"
                       Margin="0,0,0,24" />

            <!-- Loading -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="40" Height="40"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Margin="0,20" />

            <!-- Error -->
            <InfoBar Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     Severity="Error"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     IsClosable="True"
                     Margin="0,0,0,16" />

            <!-- Stats Cards -->
            <StackPanel Orientation="Horizontal"
                        Spacing="16"
                        Margin="0,0,0,32">

                <!-- Total Users -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE77B;"
                                  FontSize="28"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TotalUsers, Mode=OneWay}"
                                   FontSize="36"
                                   FontWeight="Bold" />
                        <TextBlock Text="Total Users"
                                   Opacity="0.7" />
                    </StackPanel>
                </Border>

                <!-- Licensed Users -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE8D7;"
                                  FontSize="28"
                                  Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LicensedUsers, Mode=OneWay}"
                                   FontSize="36"
                                   FontWeight="Bold" />
                        <TextBlock Text="Licensed Users"
                                   Opacity="0.7" />
                    </StackPanel>
                </Border>

                <!-- Unlicensed Users -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE783;"
                                  FontSize="28"
                                  Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.UnlicensedUsers, Mode=OneWay}"
                                   FontSize="36"
                                   FontWeight="Bold" />
                        <TextBlock Text="Unlicensed Users"
                                   Opacity="0.7" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Quick Actions -->
            <TextBlock Text="Quick Actions"
                       Style="{StaticResource SectionHeaderStyle}" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="&#xE8FA;  Create New Employee"
                        Padding="16,12"
                        Click="NavigateCreateUser_Click" />
                <Button Content="&#xE721;  Find an Employee"
                        Padding="16,12"
                        Click="NavigateManageUser_Click" />
                <Button Content="&#xE72C;  Refresh Data"
                        Padding="16,12"
                        Click="RefreshData_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

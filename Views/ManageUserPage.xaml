<Page
    x:Class="M365Manager.Views.ManageUserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:M365Manager.Models"
    xmlns:local="using:M365Manager.Views">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
        <local:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis" />
        <local:AccountStatusTextConverter x:Key="StatusText" />
        <local:ToggleAccountTextConverter x:Key="ToggleText" />
    </Page.Resources>

    <ScrollViewer Padding="40,32">
        <StackPanel MaxWidth="{StaticResource ContentMaxWidth}">

            <TextBlock Text="Manage Employees"
                       Style="{StaticResource PageHeaderStyle}" />

            <!-- Search Bar -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Find an employee by name or email address"
                               Opacity="0.7"
                               Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="SearchBox"
                                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Type a name or email..."
                                 MinWidth="400"
                                 KeyDown="SearchBox_KeyDown" />
                        <Button Content="Search"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="Search_Click"
                                Padding="20,8" />
                        <ProgressRing IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                                      Width="24" Height="24"
                                      Visibility="{x:Bind ViewModel.IsSearching, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Search Results -->
            <StackPanel Visibility="{x:Bind ViewModel.HasSearched, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Search Results"
                           Style="{StaticResource SectionHeaderStyle}" />

                <ListView ItemsSource="{x:Bind ViewModel.SearchResults}"
                          SelectionMode="None"
                          Margin="0,0,0,16">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AppUser">
                            <Grid Padding="8,12" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <PersonPicture DisplayName="{x:Bind DisplayName}"
                                               Width="40" Height="40"
                                               Grid.Column="0" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DisplayName}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Email}"
                                               Opacity="0.6"
                                               FontSize="12" />
                                </StackPanel>

                                <Button Content="View Details"
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Tag="{x:Bind}"
                                        Click="ViewUserDetails_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- Loading user -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingUser, Mode=OneWay}"
                          Width="40" Height="40"
                          Visibility="{x:Bind ViewModel.IsLoadingUser, Mode=OneWay}"
                          Margin="0,20" />

            <!-- Busy overlay -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                          Width="24" Height="24"
                          Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

            <!-- User Details Panel -->
            <StackPanel Visibility="{x:Bind ViewModel.IsUserSelected, Mode=OneWay, Converter={StaticResource BoolToVis}}">

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <Button Content="&#xE72B;  Back to search results"
                            Click="BackToSearch_Click" />
                </StackPanel>

                <!-- Profile Card -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <PersonPicture DisplayName="{x:Bind ViewModel.SelectedUser.DisplayName, Mode=OneWay}"
                                       Width="72" Height="72"
                                       Grid.Column="0"
                                       VerticalAlignment="Top" />

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="{x:Bind ViewModel.SelectedUser.DisplayName, Mode=OneWay}"
                                       FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedUser.Email, Mode=OneWay}"
                                       Opacity="0.7" />
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                <TextBlock Opacity="0.6">
                                    <Run Text="Job Title:" />
                                    <Run Text="{x:Bind ViewModel.SelectedUser.JobTitle, Mode=OneWay}" FontWeight="SemiBold" />
                                </TextBlock>
                                <TextBlock Opacity="0.6">
                                    <Run Text="Department:" />
                                    <Run Text="{x:Bind ViewModel.SelectedUser.Department, Mode=OneWay}" FontWeight="SemiBold" />
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Opacity="0.6" Margin="0,2,0,0">
                                <Run Text="Last Sign-in:" />
                                <Run Text="{x:Bind ViewModel.SelectedUser.LastSignInText, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Top" Spacing="4">
                            <Border CornerRadius="4"
                                    Padding="8,4"
                                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}">
                                <TextBlock Text="{x:Bind ViewModel.SelectedUser.AccountEnabled, Mode=OneWay, Converter={StaticResource StatusText}}"
                                           FontSize="12" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Actions Grid -->
                <Grid ColumnSpacing="16" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Profile Edit -->
                    <StackPanel Grid.Column="0" Spacing="12">

                        <!-- Edit Profile -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Update Profile"
                                           Style="{StaticResource SectionHeaderStyle}" Margin="0" />

                                <TextBox Header="Job Title"
                                         Text="{x:Bind ViewModel.EditJobTitle, Mode=TwoWay}" />
                                <TextBox Header="Department"
                                         Text="{x:Bind ViewModel.EditDepartment, Mode=TwoWay}" />
                                <TextBox Header="Office Location"
                                         Text="{x:Bind ViewModel.EditOfficeLocation, Mode=TwoWay}" />
                                <TextBox Header="Mobile Phone"
                                         Text="{x:Bind ViewModel.EditMobilePhone, Mode=TwoWay}" />
                                <TextBox Header="Business Phone"
                                         Text="{x:Bind ViewModel.EditBusinessPhone, Mode=TwoWay}" />

                                <Button Content="Save Profile Changes"
                                        Style="{StaticResource AccentButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Padding="16,8"
                                        Click="UpdateProfile_Click" />
                            </StackPanel>
                        </Border>

                        <!-- Licenses -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Licenses"
                                           Style="{StaticResource SectionHeaderStyle}" Margin="0" />

                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.SelectedUser.AssignedLicenses, Mode=OneWay}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:LicenseDetail">
                                            <Grid Padding="4" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind FriendlyName}"
                                                           VerticalAlignment="Center" />
                                                <Button Content="Remove"
                                                        Grid.Column="1"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Tag="{x:Bind}"
                                                        Click="RemoveLicense_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <ComboBox ItemsSource="{x:Bind ViewModel.AvailableLicenses}"
                                              SelectedItem="{x:Bind ViewModel.SelectedNewLicense, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayText"
                                              PlaceholderText="Choose a license..."
                                              MinWidth="250" />
                                    <Button Content="Assign"
                                            Click="AssignLicense_Click"
                                            Padding="12,6" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right: Account Actions -->
                    <StackPanel Grid.Column="1" Spacing="12">

                        <!-- Reset Password -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Reset Password"
                                           Style="{StaticResource SectionHeaderStyle}" Margin="0" />

                                <RadioButton Content="Generate a random password"
                                             IsChecked="{x:Bind ViewModel.UseRandomPassword, Mode=TwoWay}"
                                             GroupName="PasswordMode" />
                                <RadioButton Content="Set a specific password"
                                             GroupName="PasswordMode" />

                                <TextBox Header="New Password"
                                         Text="{x:Bind ViewModel.NewPassword, Mode=TwoWay}"
                                         PlaceholderText="Enter new password..." />

                                <Button Content="Generate Random"
                                        Click="GenerateRandomPwd_Click"
                                        Padding="12,6" />

                                <CheckBox Content="User must change password on next sign-in"
                                          IsChecked="{x:Bind ViewModel.ForcePasswordChange, Mode=TwoWay}" />

                                <Button Content="Reset Password"
                                        Style="{StaticResource AccentButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Padding="16,8"
                                        Click="ResetPassword_Click" />
                            </StackPanel>
                        </Border>

                        <!-- Enable/Disable Account -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Account Status"
                                           Style="{StaticResource SectionHeaderStyle}" Margin="0" />
                                <TextBlock Opacity="0.7" TextWrapping="Wrap"
                                           Text="Disabling an account will immediately prevent the person from signing in to any Microsoft 365 service." />
                                <Button Content="{x:Bind ViewModel.SelectedUser.AccountEnabled, Mode=OneWay, Converter={StaticResource ToggleText}}"
                                        Click="ToggleAccount_Click"
                                        Padding="16,8" />
                            </StackPanel>
                        </Border>

                        <!-- Group Memberships -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Teams &amp; Groups"
                                           Style="{StaticResource SectionHeaderStyle}" Margin="0" />

                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.SelectedUser.GroupMemberships, Mode=OneWay}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:GroupItem">
                                            <Grid Padding="4" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{x:Bind DisplayName}" />
                                                    <TextBlock Text="{x:Bind TypeLabel}"
                                                               FontSize="11" Opacity="0.5" />
                                                </StackPanel>
                                                <Button Content="Remove"
                                                        Grid.Column="1"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Tag="{x:Bind}"
                                                        Click="RemoveFromGroup_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <ComboBox ItemsSource="{x:Bind ViewModel.AvailableGroupsToAdd}"
                                              SelectedItem="{x:Bind ViewModel.SelectedGroupToAdd, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName"
                                              PlaceholderText="Choose a group..."
                                              MinWidth="250" />
                                    <Button Content="Add"
                                            Click="AddToGroup_Click"
                                            Padding="12,6" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Bottom spacing -->
            <Border Height="40" />
        </StackPanel>
    </ScrollViewer>
</Page>

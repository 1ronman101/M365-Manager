<Window
    x:Class="M365Manager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="M365 Manager">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Notification area (InfoBar toasts) -->
        <StackPanel x:Name="NotificationPanel"
                    Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Margin="48,8,8,0" />

        <!-- Login overlay -->
        <Grid x:Name="LoginOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
              Visibility="Visible">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        MaxWidth="400">
                <TextBlock Text="M365 Manager"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="A simple tool for managing your Microsoft 365 users"
                           TextAlignment="Center"
                           Opacity="0.7"
                           TextWrapping="Wrap" />

                <ProgressRing x:Name="LoginProgress"
                              IsActive="False"
                              Width="40" Height="40"
                              Margin="0,16,0,0" />

                <TextBlock x:Name="LoginStatusText"
                           Text=""
                           TextAlignment="Center"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />

                <Button x:Name="SignInButton"
                        Content="Sign in with your Microsoft 365 account"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center"
                        Padding="24,12"
                        Click="SignInButton_Click" />

                <HyperlinkButton Content="Open Settings to configure the app"
                                 HorizontalAlignment="Center"
                                 Click="OpenSettingsFromLogin_Click" />
            </StackPanel>
        </Grid>

        <!-- Main app shell -->
        <NavigationView x:Name="NavView"
                        Grid.Row="0" Grid.RowSpan="2"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        PaneDisplayMode="Left"
                        ItemInvoked="NavView_ItemInvoked"
                        Loaded="NavView_Loaded"
                        Visibility="Collapsed">

            <NavigationView.PaneHeader>
                <StackPanel Margin="8,8,0,8">
                    <TextBlock Text="M365 Manager"
                               FontSize="16"
                               FontWeight="SemiBold" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="Dashboard" Icon="Home" />
                <NavigationViewItem Content="Create New Employee" Tag="CreateUser">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FA;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Manage Employees" Tag="ManageUser">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Teams &amp; Groups" Tag="Groups">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE716;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Margin="12,0,12,8">
                    <TextBlock x:Name="SignedInUserText"
                               Text=""
                               FontSize="11"
                               Opacity="0.6"
                               TextTrimming="CharacterEllipsis" />
                    <HyperlinkButton Content="Sign out"
                                     FontSize="11"
                                     Padding="0"
                                     Click="SignOutButton_Click" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
